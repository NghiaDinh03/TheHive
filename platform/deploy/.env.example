# =========================================================================
# TheHive Platform — Phase 1 .env example
# Copy to .env in this directory before `docker compose up -d`.
# =========================================================================

# --- App metadata (used by Docker build args) ---
# Supported forms:
#   0.x.y-migration  -> migration-build
#   1.0.0-rc.x       -> release-candidate
#   v1.x.y           -> product-release
APP_VERSION=0.4.0-migration
GIT_SHA=local
BUILD_TIME=local

# --- Image tags (override when pulling from registry) ---
BACKEND_IMAGE=thehive-platform-backend:0.4.0-migration
FRONTEND_IMAGE=thehive-platform-frontend:0.4.0-migration

# --- Runtime env ---
APP_ENV=development
NODE_ENV=production
LOG_LEVEL=debug

# --- Ports ---
BACKEND_PORT=8080
FRONTEND_PORT=3000
POSTGRES_PORT=5432
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# --- PostgreSQL ---
POSTGRES_DB=thehive
POSTGRES_USER=thehive
POSTGRES_PASSWORD=thehive

# --- RabbitMQ ---
RABBITMQ_USER=thehive
RABBITMQ_PASSWORD=thehive

# --- Auth / security ---
# REQUIRED: at least 32 characters in non-development env.
JWT_SECRET=development-secret-change-me-development-secret
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Investigation read source ---
# Production default is postgres. legacy is for shadow compare, demo is only for local fallback.
INVESTIGATION_DATA_SOURCE=postgres

# --- Optional legacy TheHive 4 read-only adapter ---
# Leave empty to use safe demo/shadow data. Set these to proxy read-only lists from TheHive 4.
LEGACY_THEHIVE_URL=
LEGACY_THEHIVE_API_KEY=
LEGACY_THEHIVE_TIMEOUT=10s

# --- Self-hosted dev mail server ---
# Docker Compose includes Mailpit for local/self-host dev SMTP capture.
# Web UI: http://localhost:8025, SMTP: localhost:1025.
MAIL_ENABLED=true
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=thehive@localhost
PUBLIC_BASE_URL=http://localhost:3000
MAILPIT_SMTP_PORT=1025
MAILPIT_WEB_PORT=8025
