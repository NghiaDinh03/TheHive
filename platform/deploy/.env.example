# =========================================================================
# TheHive Platform — Phase 1 .env example
# Copy to .env in this directory before `docker compose up -d`.
# =========================================================================

# --- App metadata (used by Docker build args) ---
# Supported forms:
#   0.x.y-migration  -> migration-build
#   1.0.0-rc.x       -> release-candidate
#   v1.x.y           -> product-release
APP_VERSION=0.4.0-migration
GIT_SHA=local
BUILD_TIME=local

# --- Image tags (override when pulling from registry) ---
BACKEND_IMAGE=thehive-platform-backend:0.4.0-migration
FRONTEND_IMAGE=thehive-platform-frontend:0.4.0-migration

# --- Runtime env ---
APP_ENV=development
NODE_ENV=production
LOG_LEVEL=debug

# --- Ports ---
BACKEND_PORT=8080
FRONTEND_PORT=3000
POSTGRES_PORT=5432
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# --- PostgreSQL ---
POSTGRES_DB=thehive
POSTGRES_USER=thehive
POSTGRES_PASSWORD=thehive

# --- RabbitMQ ---
RABBITMQ_USER=thehive
RABBITMQ_PASSWORD=thehive

# --- Auth / security ---
# REQUIRED: at least 32 characters in non-development env.
JWT_SECRET=development-secret-change-me-development-secret
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Investigation read source ---
# Production default is postgres. legacy is for shadow compare, demo is only for local fallback.
INVESTIGATION_DATA_SOURCE=postgres

# --- Optional legacy TheHive 4 read-only adapter ---
# Leave empty to use safe demo/shadow data. Set these to proxy read-only lists from TheHive 4.
LEGACY_THEHIVE_URL=
LEGACY_THEHIVE_API_KEY=
LEGACY_THEHIVE_TIMEOUT=10s

# --- Self-hosted dev mail server ---
# SMTP mail server bị tắt ở môi trường local.
# Việc cấp tài khoản và đặt lại mật khẩu sẽ hiển thị trực tiếp link Local trên giao diện quản trị Admin.
MAIL_ENABLED=false
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=thehive@localhost
PUBLIC_BASE_URL=http://localhost:3000

# --- Attachment object storage ---
# MinIO provides S3-compatible storage for local/self-host attachment evidence.
MINIO_ROOT_USER=thehive
MINIO_ROOT_PASSWORD=thehive-secret
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=thehive
S3_SECRET_ACCESS_KEY=thehive-secret
S3_BUCKET=thehive-attachments
S3_USE_PATH_STYLE=true
S3_UPLOAD_TTL=15m
S3_DOWNLOAD_TTL=5m

# --- Attachment malware scanning ---
# clean-only blocks download until scan_status=clean. allow-unknown is dev-only.
# TheHive 4 default zip download password is malware.
ATTACHMENT_SCANNER_ENGINE=placeholder
ATTACHMENT_DOWNLOAD_POLICY=clean-only
ATTACHMENT_QUEUE_ON_UPLOAD=true
ATTACHMENT_MANUAL_SCAN_ALLOW=true
ATTACHMENT_ZIP_PASSWORD=malware

# --- MISP integration ---
# Set MISP_ENABLED=true and configure URL/API key to enable MISP connector.
MISP_ENABLED=false
MISP_URL=
MISP_API_KEY=
MISP_TIMEOUT=30s
MISP_VERIFY_TLS=true

# --- Cortex integration ---
# Set CORTEX_ENABLED=true to enable background Cortex job polling worker.
CORTEX_ENABLED=false
CORTEX_URL=
CORTEX_API_KEY=
CORTEX_TIMEOUT=30s
CORTEX_POLL_INTERVAL=30s
CORTEX_BATCH_SIZE=5
CORTEX_MAX_JOB_WAIT=5m

# --- MISP scheduled sync ---
# Set MISP_SYNC_ENABLED=true to enable periodic MISP event import as alerts.
MISP_SYNC_ENABLED=false
MISP_SYNC_INTERVAL=15m

# --- Notification worker ---
# Processes notification_queue entries and dispatches via webhook/email adapters.
NOTIFICATION_WORKER_ENABLED=true
NOTIFICATION_WORKER_POLL_INTERVAL=10s
NOTIFICATION_WORKER_BATCH_SIZE=20

# --- OpenSearch ---
# Set OPENSEARCH_ENABLED=true to enable global search and dashboard aggregation.
OPENSEARCH_ENABLED=true
OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_INDEX_PREFIX=thehive
OPENSEARCH_PORT=9200
OPENSEARCH_PERF_PORT=9600
